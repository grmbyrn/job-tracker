# Server environment variables
PORT=3000

# Postgres connection (matches docker-compose.yml — host port 5433)
DATABASE_URL=postgresql://jobtracker:jobtracker@localhost:5433/jobtracker?schema=public

# Auth (Phase 2)
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-too
# Token lifetimes (any `jsonwebtoken` expiresIn string)
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Frontend origin allowed to send the refresh cookie (Phase 5 Vite dev server)
CLIENT_ORIGIN=http://localhost:5173

# Dev seed account — the seed user is created with this (bcrypt-hashed) password
SEED_USER_PASSWORD=devpassword123
