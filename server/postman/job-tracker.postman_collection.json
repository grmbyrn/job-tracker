                  "const body = pm.response.json();",
                  "pm.test('imported counts', () => {",
                  "  pm.expect(body.imported.contacts).to.eql(2);",
                  "  pm.expect(body.imported.companies).to.eql(1);",
                  "  pm.expect(body.imported.applications).to.eql(1);",
                  "  pm.expect(body.imported.activities).to.eql(1);",
                  "});",
                  "pm.test('timers echoed, not persisted', () => pm.expect(body.timersIgnored).to.not.eql(null));"
                ]
              }
            }
