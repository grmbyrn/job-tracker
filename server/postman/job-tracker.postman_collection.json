              "raw": "{\n  \"email\": \"{{devEmail}}\",\n  \"password\": \"{{devPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const token = pm.response.json().accessToken;",
                  "pm.test('returns accessToken', () => pm.expect(token).to.be.a('string'));",
                  "pm.collectionVariables.set('accessToken', token);"
                ]
              }
            }
          ]
        },
