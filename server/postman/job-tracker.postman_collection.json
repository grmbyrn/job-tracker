            "description": "Creates a fresh user (unique email via {{$timestamp}}). Returns an access token + sets the refresh cookie. Does NOT overwrite {{accessToken}} so the rest of the run uses the seeded dev user from Login."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('returns accessToken', () => pm.expect(pm.response.json().accessToken).to.be.a('string'));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/auth/login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
