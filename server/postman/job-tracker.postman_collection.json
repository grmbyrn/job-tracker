{
  "info": {
    "name": "Job Tracker API",
    "_postman_id": "b3f1c2a4-1d2e-4f3a-9b0c-1a2b3c4d5e6f",
    "description": "Full REST surface for the Job Tracker API (Phase 2 auth + Phase 3 core CRUD + Phase 4 import).\n\nUsage:\n1. Start the API: `npm run dev:server` (defaults to http://localhost:3000) and the DB: `npm run db:up` + `npm run db:seed`.\n2. Run the whole collection top-to-bottom with the Collection Runner. Folders are ordered so created ids/token cascade: Auth > Login captures {{accessToken}}; Companies/Contacts/Applications POSTs capture their ids into collection variables that later requests reuse.\n\nAuth: the collection sends `Authorization: Bearer {{accessToken}}` by default. The Health and Auth (register/login/refresh/logout) requests override this to no-auth. The refresh endpoint relies on the httpOnly refresh cookie, which Postman stores and replays automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "devEmail", "value": "dev@jobtracker.local" },
    { "key": "devPassword", "value": "devpassword123" },
    { "key": "accessToken", "value": "" },
    { "key": "companyId", "value": "" },
    { "key": "contactId", "value": "" },
    { "key": "activityId", "value": "" },
    { "key": "applicationId", "value": "" }
  ],
